# Z1N MF Analyser — environment template
# Copy to .env and adjust values

# Postgres
POSTGRES_USER=mfa
POSTGRES_PASSWORD=mfa_password
POSTGRES_DB=mf_analyser

# Backend
DATABASE_URL=postgresql+psycopg://mfa:mfa_password@postgres:5432/mf_analyser
REDIS_URL=redis://redis:6379/0
ENVIRONMENT=development
LOG_LEVEL=INFO

# MFApi.in
MFAPI_BASE_URL=https://api.mfapi.in
MFAPI_REQUEST_DELAY_MS=100

# Scoring
RISK_FREE_RATE=0.08
MIN_NAV_HISTORY_MONTHS=36

# Monte Carlo
MONTE_CARLO_SIMULATIONS=10000

# Celery
CELERY_SCHEDULE_HOUR=23

# CORS
API_CORS_ORIGINS=http://localhost:5173

# Sentry (optional)
SENTRY_DSN=
